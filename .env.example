# Supabase PostgreSQL connection
DB_HOST=db.xxxxxxxxxxxxx.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASS=your-supabase-db-password

# Application
APP_ENV=production
APP_URL=https://your-clmis-service.onrender.com
APP_SECRET=replace-with-a-random-64-character-string

# Brevo SMTP
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=your-brevo-login-email
MAIL_PASSWORD=your-brevo-smtp-key
MAIL_FROM=noreply@yourdomain.com
MAIL_FROM_NAME=CLMIS System
