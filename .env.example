# Application
APP_ENV=local
APP_URL=http://localhost:8000
SESSION_SECRET=replace-with-a-random-string

# Database (prefer DATABASE_URL over individual DB_* vars)
DATABASE_URL=postgresql://user:password@host:6543/dbname

# Fallback individual DB settings (used if DATABASE_URL is not set)
# DB_HOST=db.xxxxxxxxxxxxx.supabase.co
# DB_PORT=5432
# DB_NAME=postgres
# DB_USER=postgres
# DB_PASS=your-password

# Supabase (for storage, etc.)
# SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
# SUPABASE_SERVICE_KEY=your-service-key
# SUPABASE_STORAGE_BUCKET=bucket-name

# Brevo SMTP
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=your-brevo-login-email
MAIL_PASSWORD=your-brevo-smtp-key
MAIL_FROM=noreply@yourdomain.com
MAIL_FROM_NAME=CLMIS System

# Paystack
PAYSTACK_SECRET_KEY=sk_test_your-secret-key
PAYSTACK_PUBLIC_KEY=pk_test_your-public-key
